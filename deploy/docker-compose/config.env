# --------------------------------------------------
# DataOps Observability Docker Compose Configuration
# --------------------------------------------------
#
# -- Alternate HTTP port in case the 8080 is already in use.
# DK_OBSERVABILITY_HTTP_PORT=
#
# -- MySQL database password configuration, as in https://hub.docker.com/_/mysql/
# DK_OBSERVABILITY_MYSQL_ROOT_PASSWORD=
# DK_OBSERVABILITY_MYSQL_PASSWORD=
#
# -- MySQL database connectivity configuration.
# DK_OBSERVABILITY_MYSQL_USER=observability
# DK_OBSERVABILITY_MYSQL_HOST=
# DK_OBSERVABILITY_MYSQL_PORT=
#
# -- Kafka connectivity configuration.
# DK_OBSERVABILITY_KAFKA_HOST=
# DK_OBSERVABILITY_KAFKA_PORT=
#
# -- Observability Enterprise Edition configuration.
# DK_OBSERVABILITY_UI_IMAGE=datakitchen/dataops-observability-enterprise-ui:v2
# DK_OBSERVABILITY_BE_IMAGE=datakitchen/dataops-observability-enterprise-be:v2
#
# -- Observability advanced deploy options.
# DK_OBSERVABILITY_API_HOSTNAME=
# DK_OBSERVABILITY_CSP_EXTRA=
# DK_OBSERVABILITY_API_BASE_URL=
# DK_OBSERVABILITY_AUTH_METHOD=
